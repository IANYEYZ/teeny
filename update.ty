versionNumber = fs.readText("pyproject.toml").split("\n")
            .filter(item => item.find(" = ") != -1)
            .filter(item => item.find("version") == 0)[0].split("=")[1].trim().slice(1, -1);
run("rmdir /s /q .\\dist");
println("Successfully cleared previous file")
run("python -m build");
println("Successfully built current version")
run("pip install .\\dist\\teeny-{versionNumber}-py3-none-any.whl --force-reinstall");
println("Successfully installed")